<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Topic List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet">
</head>
<body>
    <h1 class="mb-4">📋 Topic List</h1>
    <ul class="list-group mb-4">
        <% topics.forEach(topic => { %>
            <li class="list-group-item d-flex justifiy-content-between align-items-center">
                <div>
                    <strong><%= topic.subject %></strong> ,Topic Creator: <em><%= topic.creator %></em>
                </div>
                <a href="/topic/<%= topic.id %>" class="btn btn-outline-primary btn-sm">View</a>
            </li>    
        <% }) %>
    </ul>
    <a href="/question" class="btn btn-success">Submit a Topic Question</a>
    <a href="/answer" class="btn btn-success">Submit a Topic Answer</a>
</body>
</html>